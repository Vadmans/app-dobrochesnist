# =====================================================
# ДОБРОЧЕСНІСТЬ - Git Ignore
# Файли та папки, які НЕ потрібно завантажувати в GitHub
# =====================================================

# Python cache
# Створюється автоматично Python під час запуску
# -----------------------------------------------------
**pycache**/
*.py[cod]
*$py.class
# -----------------------------------------------------

# Virtual Environment
# Локальне середовище розробки
# На сервері Render створюється автоматично
# -----------------------------------------------------
.venv/
venv/
env/
# -----------------------------------------------------

# Environment Variables
# Секретні налаштування проєкту
# Тут можуть бути:
# DATABASE_URL
# SECRET_KEY
# FIREBASE_SERVICE_ACCOUNT_JSON
# -----------------------------------------------------
.env
.env.*
# -----------------------------------------------------

# Локальні бази даних
# Якщо використовується SQLite
# У продакшені використовується PostgreSQL (Neon)
# -----------------------------------------------------
*.db
*.sqlite
*.sqlite3
# -----------------------------------------------------

# Налаштування редакторів
# Не потрібні іншим розробникам
# -----------------------------------------------------
.vscode/
.idea/
# -----------------------------------------------------

# Системні файли Windows / macOS
# -----------------------------------------------------
Thumbs.db
.DS_Store
# -----------------------------------------------------

# Логи роботи програми
# -----------------------------------------------------
*.log
# -----------------------------------------------------

# Файли збірки
# Створюються автоматично
# -----------------------------------------------------
dist/
build/
*.egg-info/
# -----------------------------------------------------

# PyInstaller
# Файли створення EXE
# -----------------------------------------------------
*.spec
# -----------------------------------------------------

# Firebase ключі
# НІКОЛИ не викладати в GitHub
# -----------------------------------------------------
firebase-service-account.json
# -----------------------------------------------------

# Тестування
# -----------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
# -----------------------------------------------------

# Локальні файли Render
# -----------------------------------------------------
render.yaml.local
# -----------------------------------------------------

# Тимчасові резервні копії
# -----------------------------------------------------
*.bak
*.tmp
*.old
# -----------------------------------------------------

# Архіви
# -----------------------------------------------------
*.zip
*.rar
*.7z
# -----------------------------------------------------

# Локальні файли користувача
# -----------------------------------------------------
desktop.ini
